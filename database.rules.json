{
  "rules": {
    "professorOfFunk": {
      "students": {
        ".read": "auth.uid === 'FRLOpQbA69dhh7pCvx45fdPfkbz1'",
        ".write": "auth.uid === 'FRLOpQbA69dhh7pCvx45fdPfkbz1'",
        "$studentId": {
          ".read": "auth.uid === 'FRLOpQbA69dhh7pCvx45fdPfkbz1' || auth.uid === data.child('profile/authUid').val() || auth.uid === data.child('profile/parentAuthUid').val()",
          ".write": "auth.uid === 'FRLOpQbA69dhh7pCvx45fdPfkbz1'",
          "profile": {
            "accessCode": {
              ".read": true
            }
          },
          "practice": {
            ".write": "auth.uid === 'FRLOpQbA69dhh7pCvx45fdPfkbz1' || auth.uid === data.parent().child('profile/authUid').val()"
          },
          "payments": {
            "$paymentId": {
              ".write": "auth.uid === 'FRLOpQbA69dhh7pCvx45fdPfkbz1' || (auth.uid === data.parent().parent().child('profile/parentAuthUid').val() && ((newData.exists() && newData.child('status').val() === 'pending') || (!newData.exists() && data.child('status').val() === 'pending')))"
            }
          }
        }
      },
      "meta": {
        "accessCodes": {
          "$code": {
            ".read": true
          }
        },
        "parentAccessCodes": {
          "$code": {
            ".read": true
          }
        },
        "rates": {
          ".read": "auth.uid === 'FRLOpQbA69dhh7pCvx45fdPfkbz1'"
        },
        ".write": "auth.uid === 'FRLOpQbA69dhh7pCvx45fdPfkbz1'"
      },
      "parents": {
        ".read": "auth.uid === 'FRLOpQbA69dhh7pCvx45fdPfkbz1'",
        ".write": "auth.uid === 'FRLOpQbA69dhh7pCvx45fdPfkbz1'",
        "$parentId": {
          ".read": "auth.uid === 'FRLOpQbA69dhh7pCvx45fdPfkbz1' || auth.uid === data.child('profile/authUid').val()",
          ".write": "auth.uid === 'FRLOpQbA69dhh7pCvx45fdPfkbz1'",
          "profile": {
            "accessCode": {
              ".read": true
            }
          }
        }
      },
      "userProfiles": {
        "$uid": {
          ".read": "auth.uid === $uid",
          ".write": "auth.uid === $uid && !data.exists()"
        }
      },
      "ensembles": {
        ".read": "auth != null",
        ".write": "auth.uid === 'FRLOpQbA69dhh7pCvx45fdPfkbz1'"
      },
      "lessonTranscripts": {
        ".read": "auth.uid === 'FRLOpQbA69dhh7pCvx45fdPfkbz1'",
        ".write": "auth.uid === 'FRLOpQbA69dhh7pCvx45fdPfkbz1'"
      }
    }
  }
}
